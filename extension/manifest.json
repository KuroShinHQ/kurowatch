{
  "manifest_version": 3,
  "name": "KuroWatch",
  "version": "0.1.0",
  "description": "Anime/manga izlerken otomatik KuroWatch'a ekle",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://localhost:8099/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.crunchyroll.com/watch/*", "*://*.crunchyroll.com/series/*"],
      "js": ["content/common.js", "content/crunchyroll.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://diziwatch.com/*", "*://www.diziwatch.com/*"],
      "js": ["content/common.js", "content/diziwatch.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://mangadex.org/chapter/*", "*://mangadex.org/title/*"],
      "js": ["content/common.js", "content/mangadex.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.tranimeizle.co/*"],
      "js": ["content/tranimeizle.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.tranimaci.com/*"],
      "js": ["content/tranimaci.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
